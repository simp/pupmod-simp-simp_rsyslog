{
  "name": "simp-simp_rsyslog",
  "version": "1.0.0",
  "author": "SIMP Team",
  "summary": "A SIMP Puppet Profile for standard Rsyslog configurations",
  "license": "Apache-2.0",
  "source": "https://github.com/simp/pupmod-simp-simp_rsyslog",
  "project_page": "https://github.com/simp/pupmod-simp-simp_rsyslog",
  "issues_url": "https://github.com/simp/pupmod-simp-simp_rsyslog/issues",
  "tags": [
    "simp",
    "rsyslog"
  ],
  "dependencies": [
    {
      "name": "simp/rsyslog",
      "version_requirement": ">= 7.6.0 < 10.0.0"
    },
    {
      "name": "simp/simplib",
      "version_requirement": ">= 4.9.0 < 6.0.0"
    },
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">= 8.0.0 < 10.0.0"
    }
  ],
  "simp": {
    "optional_dependencies": [
      {
        "name": "simp/logrotate",
        "version_requirement": ">= 6.5.0 < 8.0.0"
      }
    ]
  },
  "operatingsystem_support": [
    {
      "operatingsystem": "CentOS",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "OracleLinux",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "Rocky",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "AlmaLinux",
      "operatingsystemrelease": [
        "8",
        "9",
        "10"
      ]
    }
  ],
  "requirements": [
    {
      "name": "openvox",
      "version_requirement": ">= 8.0.0 < 9.0.0"
    }
  ]
}
